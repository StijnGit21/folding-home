# Folding@Home Environment Variables
# Copy this file to .env and update the values

# Folding@Home Account Token (optional)
# Get your token from https://foldingathome.org/
# Leave empty if you don't have an account
ACCOUNT_TOKEN=

# Machine Name (optional)
# Display name for your machine on the Folding@Home network
MACHINE_NAME=my-folding-machine


CPU_LIMIT=2  # Limit to 2 CPU cores